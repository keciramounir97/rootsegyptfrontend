# ===============================
# FRONTEND ENV (Vite build-time)
# ===============================
# API base URL (local dev: http://localhost:5000)
VITE_API_URL=http://localhost:5000

# Optional — only if you use @supabase/supabase-js in the browser
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-jwt
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Navbar / footer click-to-call (optional; falls back in code if unset)
# E.164 digits for tel: href (no spaces):
# VITE_CONTACT_PHONE=
# Human-readable label shown next to the phone icon:
# VITE_CONTACT_PHONE_DISPLAY=
# Example:
# VITE_CONTACT_PHONE=+201234567890
# VITE_CONTACT_PHONE_DISPLAY=+20 12 345 6789
